# Routes
# This file defines all application routes (Higher priority routes first)
# https://www.playframework.com/documentation/latest/ScalaRouting
# ~~~~

# An example controller showing a sample home page
GET     /                           controllers.HomeController.index()

# Map static resources from the /public folder to the /assets URL path
GET     /assets/*file               controllers.Assets.versioned(path="/public", file: Asset)

GET     /health     controllers.HomeController.health

POST   /signup          controllers.AuthController.signup
POST   /login           controllers.AuthController.login
GET    /profile         controllers.AuthController.getProfile

GET     /signup     controllers.HomeController.signup
GET     /login      controllers.HomeController.login

POST   /posts/create    controllers.PostController.createPost
DELETE /posts/:id       controllers.PostController.deletePost(id: Long)
GET    /posts/feed      controllers.PostController.feed
GET    /uploads/*file   controllers.PostController.getUpload(file: String)

POST   /posts/:id/like/toggle      controllers.LikeController.toggleLike(id: Long)
GET    /posts/:id/likes            controllers.LikeController.getLikes(id: Long)

POST   /posts/:id/comment     controllers.CommentController.addComment(id: Long)
GET    /posts/:id/comments    controllers.CommentController.getComments(id: Long)

POST   /follow/:id      controllers.FollowController.follow(id: Long)
POST   /unfollow/:id    controllers.FollowController.unfollow(id: Long)
GET    /discover        controllers.FollowController.discover